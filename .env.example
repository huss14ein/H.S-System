# Supabase configuration
# Get these from your Supabase project dashboard under Project Settings > API
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Set to "true" to show the Sign up link on the login page and allow new user registration.
# Omit or set to anything else to keep sign-up disabled (default).
# VITE_ALLOW_SIGNUP="true"

# --- PRODUCTION ---
# Google Gemini API Key for Production (via Supabase Edge Function)
# IMPORTANT: This key MUST be set as a secret in your Supabase project environment variables.
# 1. Go to your Supabase project dashboard > Settings > Edge Functions.
# 2. Add a new secret named "GEMINI_API_KEY" with your API key as the value.

# --- LOCAL DEVELOPMENT (Optional) ---
# For local development, you can optionally bypass the Supabase function by providing the key here.
# This variable will ONLY be used in development mode and will NOT be included in production builds.
# DO NOT set this in your Netlify/production environment variables.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY_FOR_LOCAL_DEV_ONLY"

# --- AI PROVIDERS (SERVER / NETLIFY) ---
# These are configured as environment variables in Netlify (server side),
# not in the client .env files. They are listed here for reference only.
# In Netlify project settings, add:
# - GEMINI_API_KEY: Primary Google Gemini key
# - GEMINI_API_KEY_BACKUP: Optional backup Gemini key (used automatically on quota)
# - ANTHROPIC_API_KEY: Claude API key
# - CLAUDE_MODEL: Optional Claude model name (default: claude-3-5-sonnet-20241022)
# - CLAUDE_API_VERSION: Optional Claude API version (default: 2023-06-01)
# - GROK_API_KEY: xAI Grok API key
# - GROK_MODEL: Optional Grok model name (default: grok-4-0709)
