# Supabase configuration
# Get these from your Supabase project dashboard under Project Settings > API
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Set to "true" to show the Sign up link on the login page and allow new user registration.
# Omit or set to anything else to keep sign-up disabled (default).
# VITE_ALLOW_SIGNUP="true"

# --- PRODUCTION ---
# Google Gemini API Key for Production (via Supabase Edge Function)
# IMPORTANT: This key MUST be set as a secret in your Supabase project environment variables.
# 1. Go to your Supabase project dashboard > Settings > Edge Functions.
# 2. Add a new secret named "GEMINI_API_KEY" with your API key as the value.

# --- LOCAL DEVELOPMENT (Optional) ---
# For local development, you can optionally bypass the Supabase function by providing the key here.
# This variable will ONLY be used in development mode and will NOT be included in production builds.
# DO NOT set this in your Netlify/production environment variables.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY_FOR_LOCAL_DEV_ONLY"

# --- BROWSER CORS FOR NETLIFY PROXIES (gemini-proxy, sahmk-proxy, stooq-proxy) ---
# Production uses Netlify `URL` / `DEPLOY_PRIME_URL` automatically. For extra origins (custom domain,
# another dev port), set comma-separated full origins, e.g.:
# ALLOWED_ORIGINS="http://localhost:5173,https://app.yourdomain.com"

# --- PROXY ABUSE HARDENING (Netlify functions: gemini-proxy, stooq-proxy, sahmk-proxy) ---
# When set, callers must send Authorization: Bearer <Supabase access_token> (the app does this when logged in).
# Health probe POST { "health": true } stays unauthenticated so deploy checks still work without a session.
# SUPABASE_JWT_SECRET="..."   # Project Settings → API → JWT Secret (server env only, never VITE_)
# SUPABASE_URL="https://YOUR_PROJECT.supabase.co"   # Optional; if set, validates JWT `iss` matches .../auth/v1
# PROXY_REQUIRE_SUPABASE_JWT="1"

# --- AI PROVIDERS (SERVER / NETLIFY) — 4-API rotation to avoid rate limits ---
# Set in Netlify project settings. Proxy tries each in order; when one hits limit, next is used.
# - GEMINI_API_KEY: Primary Gemini key
# - GEMINI_API_KEY_BACKUP: Backup Gemini (used when primary fails)
# - ANTHROPIC_API_KEY: Claude API key
# - GROK_API_KEY: xAI Grok API key
# - OPENAI_API_KEY: OpenAI API key (gpt-4o-mini default)
# - GROK_DISABLED=1: Skip Grok in the proxy chain (e.g. key present but team has no xAI credits)
# Optional: CLAUDE_MODEL, GROK_MODEL, OPENAI_MODEL

# --- SAUDI TADAWUL LIVE QUOTES (Netlify server-only) ---
# Get a key at https://www.sahmk.sa/en/developers — used by `netlify/functions/sahmk-proxy`.
# Do not use a VITE_ prefix (keeps the key off the client). Free tier has a low daily quote cap; avoid rapid refresh.
# For `npm run dev` with @netlify/vite-plugin, set this in `.env` / Netlify so the local function can run.
# SAHMK_API_KEY="shmk_live_..."

# VITE_FINNHUB_API_KEY="..."  # US + some intl; Tadawul is often empty on free tier — SAHMK fills those gaps.

# SAR grounding audit on AI prose (development default on): flags assistant SAR amounts not present in prompt/chat JSON.
# VITE_AI_SAR_GROUNDING_AUDIT="1"   # force on in production builds
# VITE_AI_SAR_GROUNDING_AUDIT="0"   # force off everywhere
