{
  "name": "finova",
  "private": true,
  "version": "2.5.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite",
    "build:auth-shell": "tailwindcss -i ./auth-shell.css -o ./public/auth-shell.css --minify",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "node scripts/verify-stability-module-files.mjs && tsc --noEmit",
    "lint": "node scripts/lint.js",
    "debug-log-server": "node scripts/debug-log-server.js",
    "test": "npm run lint && npm run typecheck && vitest run",
    "test:unit": "vitest run",
    "verify:investment-sar-flow": "vitest run tests/investmentSarFlowMetrics.vitest.test.ts",
    "verify:budgets-bulk": "vitest run tests/householdBulkLimits.vitest.test.ts",
    "verify:regressions": "vitest run tests/investmentSarFlowMetrics.vitest.test.ts tests/householdBulkLimits.vitest.test.ts tests/investmentPlanAllocations.vitest.test.ts tests/regressionUserFixes.vitest.test.ts",
    "verify:atomic-workflows": "node scripts/verify-atomic-workflows.js",
    "test:e2e": "playwright test",
    "verify:performance-recovery": "node scripts/verify-performance-recovery.mjs",
    "verify:ai-proxy-wiring": "vitest run tests/aiProxyCompletion.vitest.test.ts tests/corsAllowlist.vitest.test.ts tests/aiProxyEndpoints.vitest.test.ts",
    "verify:deploy-wiring": "vitest run tests/deployCompletion.vitest.test.ts tests/authSessionStability.vitest.test.ts tests/wealthAnalyticsWiring.vitest.test.ts tests/canonicalHostRedirect.vitest.test.ts tests/securityWiring.vitest.test.ts tests/securityPageCoverage.vitest.test.ts tests/quotePersistenceEndToEnd.vitest.test.ts",
    "verify:login-performance": "vitest run tests/loginPerformance.vitest.test.ts tests/pageLoadingGateCoverage.vitest.test.ts",
    "deploy:production": "npm run build && node scripts/netlify-production-deploy.mjs",
    "test:release": "npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@supabase/supabase-js": "^2.91.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.6.1",
    "jose": "^5.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.2",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.1",
    "@netlify/vite-plugin": "^2.11.2",
    "@playwright/test": "^1.51.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.16",
    "netlify-cli": "^26.0.2",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
