{
  "name": "finova",
  "private": true,
  "version": "1.3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint.js",
    "debug-log-server": "node scripts/debug-log-server.js",
    "test": "npm run lint && npm run typecheck && vitest run",
    "test:unit": "vitest run",
    "verify:investment-sar-flow": "vitest run tests/investmentSarFlowMetrics.vitest.test.ts",
    "verify:budgets-bulk": "vitest run tests/householdBulkLimits.vitest.test.ts",
    "verify:regressions": "vitest run tests/investmentSarFlowMetrics.vitest.test.ts tests/householdBulkLimits.vitest.test.ts tests/investmentPlanAllocations.vitest.test.ts tests/regressionUserFixes.vitest.test.ts",
    "verify:atomic-workflows": "node scripts/verify-atomic-workflows.js",
    "test:e2e": "playwright test",
    "test:release": "npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@supabase/supabase-js": "^2.91.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.2",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.1",
    "@netlify/vite-plugin": "^2.11.2",
    "@playwright/test": "^1.51.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
